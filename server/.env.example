PORT=5000
APP_NAME=Trackence
MONGODB_URI=your_mongo_connection_url_here
FRONTEND_URL=your_frontend_url_here
REDIS_URL=rediss://default:your_upstash_password@your-upstash-host.upstash.io:6379
NODE_ENV=your_environment
OTP_PEPPER=your_otp_pepper_here
JWT_SECRET=your_jwt_secret_here

# Email provider: smtp | resend | mock
EMAIL_PROVIDER=resend

# Shared sender identity
EMAIL_FROM=no-reply@your-domain.com

# Optional category-specific sender identities (override EMAIL_FROM)
EMAIL_FROM_OTP=verify@your-domain.com
EMAIL_FROM_REPORTS=reports@your-domain.com
SUPPORT_EMAIL=support@your-domain.com

# Resend
RESEND_API_KEY=your_resend_api_key_here
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret_here

# SMTP (only required when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here
